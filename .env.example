# JobRadar — required environment variables
#
# Copy this file to `.env` (in the repo root) and fill in real values.
# See README.md → Setup for a 2-minute walkthrough.

# Postgres connection.
#
# Using `docker compose up`? Leave this as-is — the app container reaches
# Postgres at port 5432 internally. Note: the published port is 5434 (so
# psql from your laptop is `psql -h localhost -p 5434 ...`), but the URL
# below uses 5432 which is correct for in-compose networking.
#
# Running the app directly on your laptop with the docker-compose
# Postgres? Use port 5434:
#   DATABASE_URL=postgresql://jobradar:jobradar@localhost:5434/jobradar
DATABASE_URL=postgresql://jobradar:jobradar@postgres:5432/jobradar

# Anthropic API key (https://console.anthropic.com/). Bring your own.
# JobRadar's web_search agent uses claude-haiku-4-5 — typically a few
# cents per profile per day.
ANTHROPIC_API_KEY=

# Single-password admin auth. Pick something long and random.
ADMIN_PASSWORD=change-me-please

# Sign JWT tokens. Use `openssl rand -hex 64` to generate.
JWT_SECRET=change-me-to-a-long-random-string

# In-process daily cron. Default is 09:00 server-local time.
# Override examples:
#   "0 7,15 * * *"   — twice daily at 07:00 and 15:00
#   "0 */4 * * *"    — every 4 hours
# Set CRON_ENABLED=false to disable scheduling entirely (manual runs only).
CRON_SCHEDULE=0 9 * * *
CRON_ENABLED=true

# Server port. Defaults to 5173 if unset.
PORT=5173

# Set to "production" in real deployments. Enables SPA static-serving.
NODE_ENV=development
